.mcp.json

# Node modules (if any JS dependencies added)
node_modules/

# Build outputs
dist/
build/

# Project folders - ignore all uppercase directories at root
# Matches: MT360/, CDDI/, CPI/, etc.
/[A-Z]*/
/[A-Z][A-Z]*/
/[A-Z][A-Z0-9]*/
# Whitelist research workspace (case-insensitive FS on macOS causes false match above)
!platform-research/

# Docs folder (except specific public docs)
/docs/
!/docs/ai-powered-ux-workflow.md
!/docs/interview-guide.md

# Specific skills to ignore
/.claude/skills/mental-model-diagram/
